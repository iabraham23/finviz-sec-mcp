{
  "manifest_version": "0.2",
  "name": "finviz-sec-mcp",
  "version": "1.1.0",
  "description": "Free stock research MCP using Finviz and SEC data",
  "author": {
    "name": "Ishan Abraham",
    "email": "ia@cwcgroup.com",
    "url": "https://www.linkedin.com/in/ishan-abraham"
  },
  "support": "https://github.com/iabraham23/finviz-sec-mcp",
  "server": {
    "type": "python",
    "entry_point": "finviz_sec_mcp/server.py",
    "mcp_config": {
      "command": "python",
      "args": [
        "-m",
        "finviz_sec_mcp"
      ],
      "env": {
        "PYTHONPATH": "${__dirname}"
      }
    }
  },
  "tools": [
    { "name": "screen_stocks" },
    { "name": "screen_value_stocks" },
    { "name": "screen_from_url" },
    { "name": "list_filter_options" },
    { "name": "get_stock_fundamentals" },
    { "name": "compare_stocks" },
    { "name": "get_sec_filings" },
    { "name": "get_filing_text" },
    { "name": "get_financial_history" },
    { "name": "get_insider_filings" },
    { "name": "compare_sectors" },
    { "name": "compare_industries" },
    { "name": "stock_vs_industry" },
    { "name": "screen_industry" },
    { "name": "get_analyst_ratings" },
    { "name": "get_insider_activity" },
    { "name": "get_stock_news" },
    { "name": "get_earnings_news" }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iabraham23/finviz-sec-mcp"
  }
}
